  "scripts": {
    "build:js": "tsup",
    "build:styles": "tailwindcss -i ./src/styles/styles.css -o ./dist/styles.css --minify && cp ./src/styles/reset.css ./dist/reset.css",
    "build": "npm run build:js && npm run build:styles",
    "dev": "tsup --watch --ignore-watch playground --ignore-watch \"**/.next/**\"",
    "dev:playground": "npm --prefix ./playground run dev",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint"
