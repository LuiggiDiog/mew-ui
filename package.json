{
  "name": "@mew/ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./icons": { "types": "./dist/icons.d.ts", "import": "./dist/icons.js" },
    "./utils": { "types": "./dist/utils.d.ts", "import": "./dist/utils.js" },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/globals.css": "./dist/styles/globals.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:all": "npm run dev & npm --prefix ./playground run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint"
  },
  "peerDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.1.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.0",
    "sileo": "^0.1.5"
  },
  "peerDependenciesMeta": {
    "sileo": { "optional": true }
  },
  "devDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.1.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "9",
    "jsdom": "^28.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsup": "^8.3.5",
    "typescript": "5",
    "vitest": "^4.0.18"
  }
}
