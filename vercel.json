{
  "version": 2,
  "builds": [
    {
      "src": "playground/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/_next/(.*)",
      "dest": "/playground/_next/$1"
    },
    {
      "src": "/components/([^/]+)",
      "dest": "/playground/components/[category]?nxtPcategory=$1"
    },
    {
      "src": "/components/([^/]+)\\.rsc",
      "dest": "/playground/components/[category].rsc?nxtPcategory=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/playground/$1"
    }
  ]
}
